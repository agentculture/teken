[flake8]
max-line-length = 100
extend-select = B
extend-ignore =
    # whitespace before ':' — conflicts with black
    E203,
    # line break before binary operator — conflicts with black
    W503
exclude =
    .venv,
    .git,
    __pycache__,
    dist,
    build,
    # Reference trees for `afi cli cite` — contain literal {{tokens}} and are
    # intentionally not valid Python. They're package data, not code.
    afi/cite/references,
per-file-ignores =
    # Bandit S-rules are noisy in tests (assert, subprocess, etc.) — mute them.
    tests/*:S101,S404,S603
